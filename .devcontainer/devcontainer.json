{
    "name": "SpeakPal dev",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22"
        }
    },
    "remoteUser": "dev",
    "workspaceFolder": "/workspaces/SpeakPal",
    "forwardPorts": [3000, 8000],
    "containerEnv": {
        "SHELL": "/bin/zsh"
    }
}
